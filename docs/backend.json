
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a volunteer registered on the platform.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "phone": {
          "type": "string"
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" }
        },
        "location": {
          "type": "string"
        },
        "availabilityDates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "trustScore": {
          "type": "number",
          "default": 50
        },
        "missionsCompleted": {
          "type": "number",
          "default": 0
        }
      },
      "required": ["id", "name", "email"]
    },
    "Mission": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Mission",
      "type": "object",
      "description": "Represents a volunteer opportunity.",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "requiredSkills": {
          "type": "array",
          "items": { "type": "string" }
        },
        "location": {
          "type": "string"
        },
        "urgency": {
          "type": "string",
          "enum": ["Low", "Medium", "High"]
        },
        "volunteersNeeded": {
          "type": "number"
        },
        "assignedVolunteers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": {
          "type": "string",
          "enum": ["open", "in-progress", "completed"]
        }
      },
      "required": ["id", "title", "requiredSkills", "location", "urgency", "status"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/missions/{missionId}",
        "definition": {
          "entityName": "Mission",
          "schema": { "$ref": "#/backend/entities/Mission" },
          "description": "Mission details."
        }
      }
    ]
  }
}
